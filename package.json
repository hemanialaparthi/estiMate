{
    "name": "estimate-root",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "client",
        "server"
    ],
    "scripts": {
        "dev": "concurrently --names \"SERVER,CLIENT\" --colors \"cyan,blue\" \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
        "dev:server": "npm run dev --workspace=server",
        "dev:client": "npm run dev --workspace=client",
        "build": "npm run build --workspace=client && npm run build:server --workspace=server",
        "build:server": "tsc",
        "install:all": "npm install"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}